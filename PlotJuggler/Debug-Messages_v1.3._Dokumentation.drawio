        <mxCell id="TUAJ8Fo_ff5O4QPERMtA-166" parent="TUAJ8Fo_ff5O4QPERMtA-163" style="html=1;align=center;spacing=0;verticalAlign=middle;strokeColor=none;fillColor=none;whiteSpace=wrap;fontStyle=2;fontSize=10;allowArrows=0;connectable=0;rounded=1;" value="&lt;span style=&quot;font-size: 12px; font-style: normal; text-align: left;&quot;&gt;Linksdrehung&amp;nbsp;&lt;/span&gt;" vertex="1">
