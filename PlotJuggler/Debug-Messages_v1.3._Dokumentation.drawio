          <mxGeometry height="44" width="250" x="710" y="220" as="geometry" />
        </mxCell>
        <mxCell id="TUAJ8Fo_ff5O4QPERMtA-168" parent="TUAJ8Fo_ff5O4QPERMtA-167" style="html=1;align=center;spacing=0;verticalAlign=middle;strokeColor=none;fillColor=none;whiteSpace=wrap;fontStyle=1;allowArrows=0;connectable=0;rounded=1;" value="&lt;span style=&quot;text-align: left;&quot;&gt;/hyd_msg/&lt;/span&gt;&lt;span style=&quot;text-align: left;&quot;&gt;nsstatus&lt;/span&gt;&lt;span style=&quot;text-align: left;&quot;&gt;1/drv_dir_bwd (bool)&lt;/span&gt;" vertex="1">
